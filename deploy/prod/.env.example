# =============================================================================
# 生产环境变量示例
# 复制为 .env 并按需修改
# 提示:此 .env 只在 docker compose 解析时使用,不会被写入镜像/构建产物
# =============================================================================

# 主仓库根(开发工作空间) - 由 init-prod.ps1 自动写入
# docker build 需要从这里 COPY package.json + src/
SOURCE_DIR=D:\CodeProjects\LSM-CRM

# 镜像标签 - 用版本号或 git short sha
IMAGE_TAG=local

# 版本号 - 注入到前端 bundle,显示在登录页底部
VITE_APP_VERSION=0.3.0

# Git 提交 SHA - 同上,用于追溯
VITE_GIT_SHA=local

# 监听地址 - 默认仅本机;如需 LAN 访问改为 0.0.0.0
BIND_HOST=127.0.0.1

# 监听端口（生产 web 入口，从 33510 起）
BIND_PORT=33510

# API host 端口（暴露给 nginx 反代同主机访问，生产一般不暴露公网）
API_HOST_PORT=33511

# 数据库 host 端口（一般不暴露给外部，仅本机访问）
DB_HOST_PORT=33512

# 时区
TZ=Asia/Shanghai

# ---- Database (v0.3.0 新增) ----
POSTGRES_USER=lsm_crm
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_DB=lsm_crm

# ---- Session (v0.3.0 新增) ----
# 生成: openssl rand -base64 32
SESSION_SECRET=change-me-32-bytes-base64

# ---- API 日志级别 (可选) ----
LOG_LEVEL=info

# ---- CORS 白名单 (生产必需) ----
# 允许跨域访问的来源，多个用逗号分隔
# 必须以 http:// 或 https:// 开头
# 示例: https://huntercat.cn,https://www.huntercat.cn
# 如果要支持 IP 地址访问，添加: http://192.168.3.81
CORS_ORIGINS=http://192.168.3.81,https://huntercat.cn
