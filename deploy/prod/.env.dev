# =============================================================================
# dev 模式环境变量 (供 pnpm db:up 使用)
# =============================================================================
# 跟 deploy/prod/.env 的区别:
# - DB_HOST_PORT=33502 (跟 db:up 命令里的 env 覆盖一致; 避免跟 prod 33512 撞)
# - POSTGRES_PASSWORD=lsm_crm_dev (dev-only, 比 prod 安全些)
# - SESSION_SECRET 给个 dev 值
#
# 用法:
#   pnpm db:up        # 起 postgres 容器 (db 服务, 端口 33502)
#   pnpm db:down      # 停容器
#   pnpm db:migrate   # 跑迁移 (用 apps/api/.env 的 DATABASE_URL)
#   pnpm db:seed      # 灌种子
#
# 兜底 (如果 docker 镜像拉不到, 比如 Docker Desktop 代理 7897 没跑):
#   1) 用本机已装好的 Postgres 16+
#   2) 创建用户和库:
#        sudo -u postgres psql -c "CREATE USER lsm_crm WITH PASSWORD 'lsm_crm123';"
#        sudo -u postgres psql -c "CREATE DATABASE lsm_crm OWNER lsm_crm;"
#   3) 把 apps/api/.env 的 DATABASE_URL 改为 postgres://lsm_crm:lsm_crm123@localhost:5432/lsm_crm
#   4) 直接 pnpm db:migrate && pnpm db:seed (跳过 db:up)
# =============================================================================

# ---- DB 端口 (跟 db:up 命令里的 DB_HOST_PORT=33502 保持一致) ----
DB_HOST_PORT=33502

# ---- Postgres 凭据 (dev-only, 不是生产密码) ----
POSTGRES_USER=lsm_crm
POSTGRES_PASSWORD=lsm_crm_dev
POSTGRES_DB=lsm_crm

# ---- Session secret (dev 用, 生产要换) ----
SESSION_SECRET=dev-only-not-for-production-32bytes

# ---- API 日志 ----
LOG_LEVEL=info
